rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isMember(groupId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // 商品写真：そのグループのメンバーのみ読み書き可
    match /groups/{groupId}/items/{itemId}/{photo} {
      allow read: if isMember(groupId);
      allow write: if isMember(groupId)
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
